<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.CineLog" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Navy primary -->
        <item name="colorPrimary">@color/navy_primary</item>
        <item name="colorPrimaryVariant">@color/navy_dark</item>
        <item name="colorOnPrimary">@color/silver_light</item>

        <!-- Silver secondary -->
        <item name="colorSecondary">@color/silver</item>
        <item name="colorOnSecondary">@color/navy_primary</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/navy_primary</item>
        <item name="android:statusBarColor">@color/navy_dark</item>
        <item name="android:navigationBarColor">@color/navy_dark</item>

        <!-- Surface (cards, bottom nav) -->
        <item name="colorSurface">@color/navy_surface</item>
        <item name="colorOnSurface">@color/silver_light</item>
        <item name="colorOnBackground">@color/silver_light</item>

        <!-- Accent -->
        <item name="colorTertiary">@color/accent_blue</item>
    </style>
</resources>